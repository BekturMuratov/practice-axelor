<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<object-views xmlns="http://axelor.com/xml/ns/object-views"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://axelor.com/xml/ns/object-views http://axelor.com/xml/ns/object-views/object-views_6.1.xsd">

    <grid name="seo.country-grid" title="Countries" model="com.axelor.apps.base.db.Country"
          canEdit="false" canNew="false" canDelete="false" canArchive="false" edit-icon="false">
        <field name="name"/>
        <field name="fullName"/>
        <field name="numericCode"/>
        <field name="alpha3Code"/>
        <field name="alpha2Code"/>
    </grid>
    <grid name="seo.country-for.registration-grid" title="Countries" model="com.axelor.apps.base.db.Country">
        <field name="name"/>
    </grid>


    <form name="seo.country-form" title="Countries" model="com.axelor.apps.base.db.Country"
          canAttach="false" canEdit="false" canNew="false" canDelete="false" canArchive="false">
        <panel name="mainPanel">
            <field name="name" x-bind="{{name|uppercase}}"/>
            <field name="fullName"/>
            <field name="numericCode"/>
            <field name="alpha3Code" x-bind="{{alpha3Code|uppercase}}"/>
            <field name="alpha2Code" x-bind="{{alpha2Code|uppercase}}"/>
        </panel>
    </form>
</object-views>