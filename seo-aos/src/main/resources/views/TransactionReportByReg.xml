<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<object-views xmlns="http://axelor.com/xml/ns/object-views"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://axelor.com/xml/ns/object-views http://axelor.com/xml/ns/object-views/object-views_6.1.xsd">

    <form title="Transactions report by registration" name="seo.transactions.registration.report-form" model="com.axelor.utils.db.Wizard"
          canEdit="true" canSave="false" canNew="false" canArchive="false" canAttach="false"
          width="large" canDelete="false" onNew="seo.report.transactions.registration.on-new.load.action-group"
          onLoad="seo.report.transactions.registration.on-new.load.action-group">

        <!--Панель денежных сум-->
        <panel title="Money panel" readonly="true" itemSpan="3">
            <field name="$totalSumsOkTransactionsRegistration" type="decimal" title="Total sum for ok transactions" x-scale="3" colSpan="6"/>
            <field name="$amountDate" title="Amount data" type="integer" colSpan="6" min="20" max="100"
                   onChange="action-dashboard-transaction-registration-report-refresh, set.seo.report.transactions.registration.pages"/>
        </panel>

        <!--Панель транзакций 250 статус-->
        <panel title="Transactions">
            <field name="$transactionsOkPage" min="1" type="integer" title="Page" colSpan="3" onChange="action-dashboard-transaction-registration-report-refresh"/>
            <field name="$transactionOkPages" min="1" type="integer" readonly="true" title="Amount pages" colSpan="3"/>
            <field name="$transactionOkAmount" min="1" type="integer" readonly="true" title="Amount" colSpan="2"/>
            <button name="updateCustom" title="Update" onClick="action-dashboard-transaction-registration-report-refresh, seo.report.transactions.registration.on-new.load.action-group"
                    colSpan="2" icon="fa-hourglass-end" css="btn-info"/>
            <button name="exportToCsv" title="Export" onClick="com.axelor.apps.seo.web.ReportController:exportTransactionsRegistrationOk"
                    colSpan="2" icon="fa-print" css="btn-success"/>
            <panel-dashlet name="dashlet.custom.transaction.registration.ok"
                           action="dashlet.custom.custom.transaction.registration.ok.action.view" height="500" colSpan="12" css="report-box dashlet-no-dropdown"
            />
        </panel>
    </form>

    <!--Custom таблицы-->
    <custom name="custom.transaction.registration.ok" title=""  css="report-box dashlet-no-dropdown">
        <field name="payment_date" title="Payment Date" type="date"/>
        <field name="amount" title="Transaction amount" type="decimal" x-scale="3"/>
        <field name="requisite" title="Requisite" type="string"/>
        <field name="status" title="Status" type="string"/>
        <dataset type="rpc">
            com.axelor.apps.seo.web.ReportController:getTransactionsRegistrationOk
        </dataset>
        <template>
            <![CDATA[
            <style>
                .table {
                    table-layout: fixed; /* Устанавливаем фиксированную ширину для колонок */
                width: 100%;
                overflow-x: auto;
                min-width: 1000px; /* Минимальная ширина для всей таблицы */
            }

                .table thead th {
                    vertical-align: middle;
                width: 150px; /* Устанавливаем фиксированную ширину для заголовков столбцов */
                position: relative;
            }

                .table thead th .slick-sort-indicator {
                visibility: hidden;
                position: absolute;
            }

                .table tbody tr {
                height: auto;
            }

                .table tbody tr td {
                height: auto;
                white-space: normal; /* Перенос текста на новую строку */
                word-wrap: break-word;
                overflow-wrap: break-word;
                word-break: normal;
                width: 150px; /* Фиксированная ширина для ячеек */
            }
            </style>
            <div style="max-height: 450px; overflow-y: auto; width: 100%; min-width: 1000px; overflow-x: auto;">
                <report-table
                        data='data'
                        columns='payment_date, amount, requisite, status'
                />
            </div>
            ]]>
        </template>
    </custom>

    <!-- Действия при появлении таблицы-->
    <action-view name="dashlet.custom.custom.transaction.registration.ok.action.view" title="">
        <view type="custom" name="custom.transaction.registration.ok"/>
        <context name="page" expr="eval: transactionsOkPage != null? transactionsOkPage : 1"/>
        <context name="pageSize" expr="eval: amountDate != null? amountDate : 40"/>
    </action-view>

    <!--Группа действий при появлении отчета-->
    <action-group name="seo.report.transactions.registration.on-new.load.action-group">
        <action name="set.dates.report.transactions.registration.action"/>
        <action name="set.seo.report.transactions.registration.pages"/>
        <action name="set.seo.total.sum.transactions.registration"/>
    </action-group>

    <!--Метод 1 с группы создания отчета задаем значения по умолчанию -->
    <action-attrs name="set.dates.report.transactions.registration.action">
        <attribute for="$transactionsOkPage" name="value" expr="eval: 1"/>
        <attribute for="$amountDate" name="value" expr="eval: 40"/>
    </action-attrs>

    <!--Метод 2 с группы создания отчета задаем значения всем страницам -->
    <action-method name="set.seo.report.transactions.registration.pages">
        <call class="com.axelor.apps.seo.web.ReportController" method="getPagesInfoTransactionsRegistration"/>
    </action-method>

    <!--Метод 3 с группы создания отчета вычисляем суммы -->
    <action-method name="set.seo.total.sum.transactions.registration">
        <call class="com.axelor.apps.seo.web.ReportController" method="calculateTotalSumTransactionsRegistration"/>
    </action-method>

    <!--Обновление таблиц-->
    <action-attrs name="action-dashboard-transaction-registration-report-refresh">
        <attribute name="refresh" expr="eval: true" for="dashlet.custom.transaction.registration.ok" />
    </action-attrs>


</object-views>
