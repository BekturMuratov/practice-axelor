<?xml version="1.0" encoding="UTF-8"?>
<domain-models xmlns="http://axelor.com/xml/ns/domain-models"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="http://axelor.com/xml/ns/domain-models http://axelor.com/xml/ns/domain-models/domain-models_6.1.xsd">

    <module name="seo" package="com.axelor.apps.seo.db" />

    <entity name="Camera">
        <string name="crossRecordSyscode" title="Cross record syscode"/>                                                <!-- Код-->
        <datetime name="crossTime" title="Cross time"/>                                                                 <!-- Дата и время-->
        <string name="plateNo" title="PlateNO"/>                                                                        <!-- Номер машины-->
        <string name="point" title="Point"/>                                                                            <!-- Пункт-->
        <string name="contact" title="Contact"/>                                                                        <!-- Контакт-->
        <many-to-one name="ccp" title="CCP" ref="com.axelor.apps.seo.db.CustomsCheckpoint"/>                            <!-- ПП-->
        <string name="vehiclePicUri" title="Vehicle pic uri"/>                                                          <!-- Фото-->
        <string name="vehicleType" title="Vehicle type" selection="seo.camera.types.select"/>                           <!-- Тип машины-->
        <string name="vehicleColor" title="Vehicle color" selection="seo.camera.color.select"/>                         <!-- Цвет-->
        <string name="cameraIndexCode" title="Camera index code"/>                                                      <!-- Номер камеры-->
        <string name="country" title="Country"/>                                                                        <!-- Страна-->
        <string name="vehicleDirectionType" title="Vehicle direction type"
                selection="seo.camera.directions.select"/>                                                              <!-- Въезд/Выезд-->
        <many-to-one name="registration" ref="com.axelor.apps.seo.db.Registration"/>                                    <!-- Регистрация-->
        <string name="infoVehicleDirectionType" title="Info Vehicle direction type"
                selection="seo.camera.directions.select"/>                                                              <!-- Тип направления(info)-->
    </entity>
</domain-models>