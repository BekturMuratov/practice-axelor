<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<object-views xmlns="http://axelor.com/xml/ns/object-views"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://axelor.com/xml/ns/object-views http://axelor.com/xml/ns/object-views/object-views_6.1.xsd">

    <grid title="Tariff" name="tariff-grid" model="com.axelor.apps.svh.db.Tariff">
        <field name="name"/>
        <field name="tariffType"/>
        <field name="timeCalculationType"/>
        <field name="baseDays" />
        <field name="maxWeight"/>
        <field name="priceUpToWeight"/>
        <field name="priceUpToWeightAfter"/>
        <field name="priceAboveWeight" />
        <field name="priceAboveWeightAfter"/>
        <field name="dailyPrice" />
        <field name="priceAfterChange" />
    </grid>

    <form name="tariff-form"
          title="Tariff"
          model="com.axelor.apps.svh.db.Tariff" width="large">

        <panel title="Main Information">
            <field name="name" colSpan="3"/>
            <field name="tariffType" colSpan="3"/>
            <field name="startDateTime" colSpan="3"/>
            <field name="endDateTime" colSpan="3"/>
        </panel>


        <!-- Грузовой транспорт -->

        <panel title="Truck tariff"
               showIf="tariffType == 'TRUCK'">
            <field name="maxWeight" colSpan="3"/>
            <field name="priceUpToWeight" colSpan="3"/>
            <field name="baseDays" colSpan="3"/>
            <field name="priceUpToWeightAfter" colSpan="3"/>
            <field name="timeCalculationType" colSpan="3"/>
            <field name="priceAboveWeight" colSpan="3"/>
            <field name="priceAboveWeightAfter" colSpan="3"/>
        </panel>


        <!-- Автовоз / Спецтехника / Легковой -->

        <panel title="Тариф хранения"
               showIf="tariffType != 'TRUCK'">
            <field name="dailyPrice" colSpan="3"/>
            <field name="timeCalculationType" colSpan="3"/>
            <field name="baseDays" colSpan="3"/>
            <field name="priceAfterChange" colSpan="3"/>
        </panel>

    </form>
</object-views>