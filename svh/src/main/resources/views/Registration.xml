<?xml version="1.0" encoding="UTF-8" standalone="yes"?>

<object-views xmlns="http://axelor.com/xml/ns/object-views"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://axelor.com/xml/ns/object-views
              http://axelor.com/xml/ns/object-views/object-views_6.1.xsd">

    <!-- ===================================================== -->
    <!-- GRID -->
    <!-- ===================================================== -->

    <grid title="Registration"
          name="registration-grid"
          model="com.axelor.apps.svh.db.Registration">

        <field name="uId"/>
        <field name="createdOn" title="Create On"/>
        <field name="releasedOn" title="Released On"/>
        <field name="transport_type" widget="singleSelect"/>
        <field name="drivers_full_name"/>
        <field name="phone_number" widget="phone" x-initial-country="KG"/>
        <field name="plate_no"/>
        <field name="plate_no_trailer"/>
        <field name="serial_number"/>
        <field name="vin_code"/>
        <field name="weight"/>
        <field name="calculated_amount"/>

    </grid>


    <!-- ===================================================== -->
    <!-- FORM -->
    <!-- ===================================================== -->

    <form title="Registration Form"
          name="registration-form"
          width="large"
          model="com.axelor.apps.svh.db.Registration"
          onSave="registration.normalizeAndValidateOnSave">

        <!-- ================= Overview ================= -->

        <panel name="registrationOverviewPanel"
               title="Overview"
               colSpan="7">

            <field name="uId" readonly="true" colSpan="2"/>
            <field name="drivers_full_name" colSpan="2"/>
            <field name="country" colSpan="2"/>
            <field name="phone_number"
                   widget="phone"
                   x-initial-country="KG"
                   colSpan="2"/>

            <field name="transport_type"
                   widget="singleSelect"
                   selection="svh.registration.transport_types_selections"
                   colSpan="2"/>

        </panel>


        <!-- ================= Company Car ================= -->

        <panel name="companyCar"
               title="Company Car"
               showIf="transport_type == 'COMPANY_CAR'">

            <field name="plate_no"
                   onChange="registration.normalize"/>

        </panel>


        <!-- ================= Passenger ================= -->

        <panel name="passengerTransport"
               title="Passenger Transport"
               showIf="transport_type == 'PASSENGER'">

            <field name="vin_code"
                   onChange="registration.normalize"/>

        </panel>


        <!-- ================= Special Equipment ================= -->

        <panel name="specialEquipment"
               title="Special Equipment"
               showIf="transport_type == 'SPECIAL'">

            <field name="serial_number"
                   onChange="registration.normalize"/>

            <field name="plate_no"
                   onChange="registration.normalize"/>

            <field name="plate_no_trailer"
                   onChange="registration.normalize"/>

        </panel>


        <!-- ================= Car Carrier ================= -->

        <panel name="carCarrier"
               title="Car Carrier"
               showIf="transport_type == 'CAR_CARRIER'">

            <field name="plate_no"
                   onChange="registration.normalize"/>

            <field name="plate_no_trailer"
                   onChange="registration.normalize"/>

        </panel>


        <!-- ================= Freight Transport ================= -->

        <panel name="TRUCK"
               title="TRUCK"
               showIf="transport_type == 'TRUCK'">

            <field name="plate_no_trailer"
                   onChange="registration.normalize"/>

            <field name="weight"/>

        </panel>


        <!-- ================= Calculation Panel ================= -->

        <panel name="CalculatePanel"
               sidebar="true"
               title="Calculate"
               showIf="id != null &amp;&amp; transport_type != 'COMPANY_CAR'">

            <field name="calculated_amount"/>

            <button name="calculateTariffBtn"
                    title="Calculate storage cost"
                    onClick="tariff.calculate"/>

        </panel>


        <!-- ================= Actions ================= -->

        <panel name="formActionsPanel"
               sidebar="true"
               title="Actions">

            <button name="saveBtn"
                    title="Save"
                    onClick="save"
                    color="green"/>

            <button name="cancelBtn"
                    title="Cancel"
                    onClick="cancel"
                    color="red"/>

        </panel>


        <panel-mail>
            <mail-messages/>
        </panel-mail>

    </form>


    <!-- ===================================================== -->
    <!-- ACTIONS -->
    <!-- ===================================================== -->

    <action-method name="tariff.calculate">
        <call class="com.axelor.apps.svh.web.TariffController"
              method="calculateTariff"/>
    </action-method>

    <action-method name="registration.normalize">
        <call class="com.axelor.apps.svh.web.RegistrationController"
              method="normalizeOnChange"/>
    </action-method>

</object-views>